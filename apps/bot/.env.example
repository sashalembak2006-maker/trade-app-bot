# === Telegram Bot (apps/bot) ===
# Скопіюйте як apps/bot/.env і заповніть значення.

# Токен бота від @BotFather (обовʼязково)
BOT_TOKEN=your_telegram_bot_token

# Назва бота у привітанні /start (за замовчуванням TRADE APP BOT)
BOT_DISPLAY_NAME=TRADE APP BOT

# URL Mini App — HTTPS домен, зареєстрований у BotFather (обовʼязково)
WEBAPP_URL=https://your-domain.com

# URL бекенду API (на VPS зазвичай http://127.0.0.1:3001)
API_URL=http://localhost:3001

# Секрет для внутрішніх запитів бота до /api/bot-admin (обовʼязково, той самий що в API)
INTERNAL_API_SECRET=dev-internal-secret

# Telegram ID адміністраторів через кому (обовʼязково для /admin)
TELEGRAM_ADMIN_IDS=123456789

# Реферальне посилання Pocket Option
POCKET_REFERRAL_URL=https://pocketoption.com/cabinet/demo-quick-high-low/

# Окреме посилання для поповнення депозиту (якщо відрізняється від реєстрації)
DEPOSIT_URL=https://pocketoption.com/cabinet/demo-quick-high-low/

# Підтримка та відгуки (кнопки в меню бота)
SUPPORT_URL=https://t.me/your_support
REVIEWS_URL=https://t.me/your_reviews

# Обовʼязковий канал для підписки (@channel або -100xxxxxxxxxx)
REQUIRED_CHANNEL_ID=@your_channel
REQUIRED_CHANNEL_URL=https://t.me/your_channel

# Зображення привітання (URL). Якщо порожньо — використовується apps/bot/assets/welcome.png
WELCOME_IMAGE_URL=

# Мінімальна сума депозиту (для тексту інструкції)
MIN_DEPOSIT_AMOUNT=100

# =============================================================================
# PRIME TRADE BOT — Production environment (copy to apps/api/.env, apps/bot/.env,
# apps/collector/.env and fill in real values)
# =============================================================================

NODE_ENV=production

# --- Public URLs (used after you buy a domain + SSL) ---
# Mini App URL — set in @BotFather as Web App URL
WEBAPP_URL=https://your-domain.com
# API base (same host if nginx proxies /api, or api.your-domain.com)
PUBLIC_API_URL=https://your-domain.com
PUBLIC_WS_URL=wss://your-domain.com/ws

# --- API (apps/api/.env) ---
API_PORT=3001
CORS_ORIGIN=https://your-domain.com
DATABASE_URL="file:./prod.db"
MARKET_DATA_MODE=platform
# Production: real PO prices only (no simulated hybrid). Dev: set true for local testing without collector.
# Hybrid micro-ticks for non-active pairs in Mini App (default ON when BRIDGE_SECRET is set)
PLATFORM_SYNTHETIC_FALLBACK=true
BRIDGE_SECRET=CHANGE_ME_long_random_bridge_secret
COLLECTOR_SECRET=CHANGE_ME_long_random_collector_secret
INTERNAL_API_SECRET=CHANGE_ME_long_random_internal_secret
ALLOW_RUNTIME_MODE_SWITCH=false
LOG_LEVEL=info

MIN_DEPOSIT_AMOUNT=100
ADMIN_EMAIL=admin@primetrade.bot
ADMIN_PASSWORD=CHANGE_ME_strong_password
TELEGRAM_ADMIN_IDS=123456789
ADMIN_TELEGRAM_IDS=123456789
POCKET_REFERRAL_URL=https://pocketoption.com/cabinet/demo-quick-high-low/
SUPPORT_URL=https://t.me/your_support
REVIEWS_URL=https://t.me/your_reviews
SIGNAL_PRICE_WAIT_MS=4000

# Serve built Mini App from API (optional — or use PM2 prime-web + nginx)
WEB_DIST_PATH=../../web/dist

# --- Telegram Bot (apps/bot/.env) ---
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
WEBAPP_URL=https://your-domain.com
API_URL=http://127.0.0.1:3001

# --- Web build-time (apps/web/.env — used only during npm run build) ---
VITE_API_URL=https://your-domain.com
VITE_WS_URL=wss://your-domain.com/ws
VITE_BOT_USERNAME=@YourPrimeTradeBot

# --- VPS Data Collector (apps/collector/.env) — technical Pocket session, NOT user passwords ---
API_URL=http://127.0.0.1:3001
BRIDGE_SECRET=same_as_api_BRIDGE_SECRET
COLLECTOR_SECRET=same_as_api_COLLECTOR_SECRET
PO_WS_URL=wss://api-eu.po.market/socket.io/?EIO=4&transport=websocket
PO_AUTH_MESSAGE=42["auth",{"session":"PASTE_FROM_BROWSER_DEVTOOLS","isDemo":0,"uid":12345}]
COLLECTOR_PUSH_INTERVAL_MS=1000
COLLECTOR_HEARTBEAT_MS=10000
